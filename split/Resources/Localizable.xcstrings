    "deleteAccount.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All your trips, expenses, and receipt images will be permanently deleted. This action cannot be undone."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All your trips, expenses, and receipt images will be permanently deleted. This action cannot be undone."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos tus viajes, gastos e imágenes de recibos se eliminarán permanentemente. Esta acción no se puede deshacer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての旅行、経費、レシート画像が完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 여행, 경비, 영수증 이미지가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有行程、消费记录和收据图片将被永久删除，此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有行程、消費記錄和收據圖片將被永久刪除，此操作無法復原。"
          }
        }
      }
    },
